grow_horizontal = 2
grow_vertical = 2
theme_override_fonts/normal_font = ExtResource("7_fy4q0")
theme_override_font_sizes/normal_font_size = 22
text = "And you will again.

Every spell you cast feeds the fire. Every enemy you strike stokes it higher. Rage is no longer a weakness—it is your weapon, your fuel, your curse. The more you embrace it, the stronger you become… but the closer you drift to something far more dangerous than your enemies.

Control is an illusion.

Power is a choice.

How far will you go before the rage consumes you?"
scroll_active = false
visible_characters = 0
visible_characters_behavior = 1
visible_ratio = 0.0

