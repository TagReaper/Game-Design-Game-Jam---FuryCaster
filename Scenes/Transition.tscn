text = "The air trembles before the first spark ever forms.

Magic was never meant to feel like this.

Not calm. Not controlled. Not safe.

You feel it clawing inside you—heat behind your ribs, a pressure in your veins, something ancient and furious begging to be released. Other sorcerers speak of focus and discipline… but they’ve never felt this. They’ve never stood on the edge of losing themselves just to gain power.

You have."
scroll_active = false
autowrap_mode = 2
visible_characters = 0
visible_characters_behavior = 1
visible_ratio = 0.0

[node name="RichTextLabel2" type="RichTextLabel" parent="CanvasLayer"]
visible = false
